<?xml version="1.0" encoding="UTF-8"?>
<!--
    1553B数据智能分析工具 - 配置文件
    
    本文件定义了应用程序的所有可配置参数，包括：
    - Parser: 二进制文件解析参数（字节序、包头标识、时间戳单位等）
    - GanttChart: 甘特图颜色配置（按消息类型区分颜色）
    - Database: 数据库模式切换阈值
    - Models: AI模型提供商配置（API密钥、URL、系统提示词）
    - Export: 数据导出默认参数
    
    修改此文件后需要重启应用程序才能生效。
-->
<Config version="1.0">
    <!--
        解析器配置
        - ByteOrder: 字节序，big=大端序，little=小端序
        - Header1: 包头1标识（16位十六进制）
        - Header2: 包头2标识（8位十六进制）
        - DataHeader: 数据头标识（16位十六进制）
        - TimestampUnit: 时间戳单位（微秒），40表示每计数=40微秒
        - MaxErrorTolerance: 最大错误容忍数，超过此数的包将被跳过
    -->
    <Parser>
        <ByteOrder>big</ByteOrder>
        <Header1>0xA5A5</Header1>
        <Header2>0xA5</Header2>
        <DataHeader>0xAABB</DataHeader>
        <TimestampUnit>40</TimestampUnit>
        <MaxErrorTolerance>100</MaxErrorTolerance>
    </Parser>
    
    <!--
        甘特图颜色配置
        - ColorBC2RT: BC→RT消息颜色（蓝色）
        - ColorRT2BC: RT→BC消息颜色（绿色）
        - ColorRT2RT: RT→RT消息颜色（橙色）
        - ColorBroadcast: 广播消息颜色（紫色）
        - ColorError: 错误消息颜色（红色）
    -->
    <GanttChart>
        <ColorBC2RT>#3498DD</ColorBC2RT>
        <ColorRT2BC>#2ECC71</ColorRT2BC>
        <ColorRT2RT>#F39C12</ColorRT2RT>
        <ColorBroadcast>#9B59B6</ColorBroadcast>
        <ColorError>#E74C3C</ColorError>
    </GanttChart>
    
    <!--
        数据库配置
        - RecordThreshold: 切换到数据库模式的记录数阈值（单位：万条）
          当导入数据超过此阈值时，自动从内存模式切换到SQLite数据库模式
    -->
    <Database>
        <RecordThreshold>10</RecordThreshold>
    </Database>
    
    <!--
        AI模型配置
        - DefaultModel: 默认使用的模型，格式为"提供商ID.模型名"
        - ApiTimeout: API调用超时时间（秒）
        - RetryCount: 请求失败重试次数
        
        每个Provider包含：
        - id: 提供商唯一标识
        - name: 显示名称
        - Instance: 模型实例（可配置多个）
          - name: 模型名称
          - enabled: 是否启用
          - ApiKey: API密钥（Ollama本地模型可为空）
          - ApiUrl: API接口地址
          - SystemPrompt: 系统提示词（定义AI角色和行为）
    -->
    <Models>
        <DefaultModel>qwen.qwen-plus</DefaultModel>
        <ApiTimeout>60</ApiTimeout>
        <RetryCount>3</RetryCount>
        
        <Provider id="qwen" name="千问">
            <Instance name="qwen-plus" enabled="true">
                <ApiKey>sk-cff867681d5941ebab94f5d51f1c51e3</ApiKey>
                <ApiUrl>https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation</ApiUrl>
                <SystemPrompt>你是一个1553B总线数据分析专家，请根据用户的问题分析数据并给出专业的回答。</SystemPrompt>
            </Instance>
            <Instance name="qwen-max" enabled="true">
                <ApiKey>sk-cff867681d5941ebab94f5d51f1c51e3</ApiKey>
                <ApiUrl>https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation</ApiUrl>
                <SystemPrompt>你是一个1553B总线数据分析专家，请根据用户的问题分析数据并给出专业的回答。</SystemPrompt>
            </Instance>
        </Provider>
        
        <Provider id="deepseek" name="DeepSeek">
            <Instance name="deepseek-chat" enabled="true">
                <ApiKey>sk-b2aaff0d27224b69ba51ab96d94a5cb9</ApiKey>
                <ApiUrl>https://api.deepseek.com/v1/chat/completions</ApiUrl>
                <SystemPrompt>你是一个1553B总线数据分析专家，请根据用户的问题分析数据并给出专业的回答。</SystemPrompt>
            </Instance>
        </Provider>
        
        <Provider id="kimi" name="Kimi">
            <Instance name="moonshot-v1-8k" enabled="true">
                <ApiKey>sk-uX6XV2rcBn3C8azHhJvhgHcdGAl2dkmRAaMdevCVJNkc9c47</ApiKey>
                <ApiUrl>https://api.moonshot.cn/v1/chat/completions</ApiUrl>
                <SystemPrompt>你是一个1553B总线数据分析专家，请根据用户的问题分析数据并给出专业的回答。</SystemPrompt>
            </Instance>
        </Provider>
        
        <Provider id="ollama" name="Ollama">
            <Instance name="qwen2.5:7b" enabled="true">
                <ApiKey></ApiKey>
                <ApiUrl>http://localhost:11434/api/chat</ApiUrl>
                <SystemPrompt>你是一个1553B总线数据分析专家，请根据用户的问题分析数据并给出专业的回答。</SystemPrompt>
            </Instance>
        </Provider>
    </Models>
    
    <!--
        导出配置
        - DefaultFormat: 默认导出格式（csv/excel）
        - Encoding: 文件编码
        - ReportFormat: 报告默认格式（html/pdf/docx）
    -->
    <Export>
        <DefaultFormat>csv</DefaultFormat>
        <Encoding>UTF-8</Encoding>
        <ReportFormat>html</ReportFormat>
    </Export>
</Config>
