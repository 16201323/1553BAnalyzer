*.raw
*.recovered
*~

# Trae IDE generated files
docs/superpowers/
.trae/

# Binaries - general exclusion
*.exe
*.a
*.pdb
*.so
*.dylib

# DLL and LIB - exclude generally, but keep vosk library
*.dll
*.lib

# Vosk library files - exception to DLL/LIB rules above
# (negation patterns must come AFTER the exclusion patterns)
!libs/vosk/**/*.dll
!libs/vosk/**/*.lib
!libs/vosk/**/*.zip
!libs/vosk/**/*.h
